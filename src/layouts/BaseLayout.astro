---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "AppEx" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon-64.png" />
  </head>
  <body>
    <slot />
  </body>
</html>