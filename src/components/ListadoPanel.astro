---
<section class="section-container py-10">
  <div
    id="listados-panel-root"
    class="rounded-[20px] border border-white/10 bg-[#05070b] p-6 text-white shadow-[0_12px_40px_rgba(0,0,0,0.28)]"
  >
    <div class="flex flex-wrap items-center gap-8 border-b border-white/5 pb-4">
      {tabs.map((tab, index) => (
        <button
          type="button"
          class:list={['panel-tab', index === 0 && 'active']}
          data-tab={tab.id}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <div class="mt-6 flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-end">
      <div class="relative w-full max-w-[320px]">
        <input
          id="panel-search"
          type="text"
          placeholder="Search"
          class="w-full rounded-[8px] border border-white/10 bg-transparent px-10 py-3 text-sm text-white outline-none placeholder:text-slate-500"
        />
        <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-slate-500">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 5.5 5.5a7.5 7.5 0 0 0 11.15 11.15Z" />
          </svg>
        </span>
      </div>

      <select
        id="panel-sort"
        class="rounded-[8px] border border-white/10 bg-transparent px-4 py-3 text-sm text-white outline-none"
      >
        <option value="recent" class="bg-[#111]">Sort by last updated</option>
        <option value="az" class="bg-[#111]">Ordenar A-Z</option>
      </select>
    </div>

    <div id="panel-list" class="mt-4 space-y-3"></div>

    <div class="mt-8 flex flex-col gap-3 text-sm text-slate-400 sm:flex-row sm:items-center sm:justify-end">
      <span id="panel-total">Total 0</span>

      <div class="flex items-center gap-3">
        <button
          id="panel-prev"
          type="button"
          class="text-slate-500 transition hover:text-white"
        >
          ‹
        </button>

        <span
          id="panel-page"
          class="inline-flex min-w-[36px] h-8 items-center justify-center rounded-[6px] border border-cyan-400 px-3 text-cyan-400"
        >
          1
        </span>

        <button
          id="panel-next"
          type="button"
          class="text-slate-500 transition hover:text-white"
        >
          ›
        </button>
      </div>

      <select
        id="panel-per-page"
        class="rounded-[8px] border border-white/10 bg-transparent px-3 py-2 text-sm text-white outline-none"
      >
        <option value="5" class="bg-[#111]" selected>5/page</option>
        <option value="10" class="bg-[#111]">10/page</option>
        <option value="20" class="bg-[#111]">20/page</option>
      </select>
    </div>
  </div>
</section>

<script define:vars={{ itemsByTab }}>
  const root = document.getElementById('listados-panel-root');

  if (!root) {
    throw new Error('No se encontró el contenedor del panel de listados');
  }

  const tabButtons = root.querySelectorAll('[data-tab]');
  const listEl = root.querySelector('#panel-list');
  const totalEl = root.querySelector('#panel-total');
  const pageEl = root.querySelector('#panel-page');
  const searchEl = root.querySelector('#panel-search');
  const sortEl = root.querySelector('#panel-sort');
  const prevBtn = root.querySelector('#panel-prev');
  const nextBtn = root.querySelector('#panel-next');
  const perPageEl = root.querySelector('#panel-per-page');

  let activeTab = 'alarmas';
  let currentPage = 1;
  let itemsPerPage = 5;

  function badgeClasses(tone) {
    if (tone === 'danger') return 'bg-red-500/10 text-red-300 border border-red-500/20';
    if (tone === 'warning') return 'bg-amber-500/10 text-amber-300 border border-amber-500/20';
    if (tone === 'success') return 'bg-emerald-500/10 text-emerald-300 border border-emerald-500/20';
    if (tone === 'info') return 'bg-sky-500/10 text-sky-300 border border-sky-500/20';
    return 'bg-white/5 text-slate-300 border border-white/10';
  }

  function getFilteredItems() {
    const source = [...(itemsByTab[activeTab] || [])];
    const term = (searchEl?.value || '').toLowerCase().trim();
    const sortMode = sortEl?.value || 'recent';

    let items = source.filter((item) => {
      return [item.title, item.subtitle, item.meta, item.badge]
        .join(' ')
        .toLowerCase()
        .includes(term);
    });

    if (sortMode === 'az') {
      items.sort((a, b) => a.title.localeCompare(b.title));
    } else {
      items.sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));
    }

    return items;
  }

  function renderList() {
    const items = getFilteredItems();

    if (!listEl || !totalEl || !pageEl) return;

    const totalPages = Math.max(1, Math.ceil(items.length / itemsPerPage));

    if (currentPage > totalPages) {
      currentPage = totalPages;
    }

    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    const paginatedItems = items.slice(start, end);

    totalEl.textContent = `Total ${items.length}`;
    pageEl.textContent = String(currentPage);

    if (prevBtn) prevBtn.disabled = currentPage === 1;
    if (nextBtn) nextBtn.disabled = currentPage === totalPages;

    if (!paginatedItems.length) {
      listEl.innerHTML = `
        <div class="rounded-[14px] border border-white/10 bg-white/[0.02] px-4 py-6 text-sm text-slate-400">
          No se encontraron resultados para esta categoría.
        </div>
      `;
      return;
    }

    listEl.innerHTML = paginatedItems.map((item) => `
      <article class="rounded-[12px] border border-white/10 bg-white/[0.03] px-4 py-4 transition hover:border-white/20 hover:bg-white/[0.045]">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div class="min-w-0">
            <h3 class="truncate text-[17px] font-medium leading-tight text-white">
              ${item.title}
            </h3>
            <p class="mt-1 text-sm text-slate-400">
              ${item.subtitle} | ${item.meta}
            </p>
          </div>

          <div class="flex items-center gap-3 self-start sm:self-center">
            <span class="inline-flex rounded-full px-3 py-1 text-sm ${badgeClasses(item.badgeTone)}">
              ${item.badge}
            </span>

            <button type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-[8px] border border-white/10 text-slate-400 transition hover:bg-white/5 hover:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                <path d="M12 6.75a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3ZM12 13.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3ZM12 20.25a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" />
              </svg>
            </button>
          </div>
        </div>
      </article>
    `).join('');
  }

  function setActiveTab(tabId) {
    activeTab = tabId;
    currentPage = 1;

    tabButtons.forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.tab === tabId);
    });

    renderList();
  }

  tabButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      setActiveTab(btn.dataset.tab);
    });
  });

  searchEl?.addEventListener('input', () => {
    currentPage = 1;
    renderList();
  });

  sortEl?.addEventListener('change', () => {
    currentPage = 1;
    renderList();
  });

  perPageEl?.addEventListener('change', (e) => {
    itemsPerPage = Number(e.target.value);
    currentPage = 1;
    renderList();
  });

  prevBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderList();
    }
  });

  nextBtn?.addEventListener('click', () => {
    const totalItems = getFilteredItems().length;
    const totalPages = Math.max(1, Math.ceil(totalItems / itemsPerPage));

    if (currentPage < totalPages) {
      currentPage++;
      renderList();
    }
  });

  setActiveTab(activeTab);
</script>

<style>
  .panel-tab {
    position: relative;
    padding-bottom: 0.7rem;
    font-size: 1.05rem;
    color: rgb(226 232 240 / 0.85);
    transition: color 0.25s ease;
  }

  .panel-tab:hover {
    color: white;
  }

  .panel-tab::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 100%;
    height: 2px;
    border-radius: 999px;
    background: #00d3f3;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .panel-tab.active {
    font-weight: bold;
    color: #68ebff;
  }

  .panel-tab.active::after {
    transform: scaleX(1);
  }

  #panel-prev:disabled,
  #panel-next:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
</style>